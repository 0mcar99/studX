# App
NODE_ENV=development
APP_NAME=StudyShare AI
APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/studyshare_ai

# Authentication
JWT_SECRET=replace-with-long-random-secret
NEXTAUTH_SECRET=replace-with-nextauth-secret
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
AI_DAILY_TOKEN_LIMIT=250000

# Storage: AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=ap-south-1
AWS_S3_BUCKET=studyshare-ai-assets

# Storage: Supabase (optional)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Storage: Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Security and Limits
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
LOGIN_MAX_ATTEMPTS=5
MAX_FILE_SIZE_MB=150
ALLOWED_FILE_TYPES=pdf,ppt,pptx,doc,docx,txt,png,jpg,jpeg,mp3,wav,mp4,mov

# Monitoring
ENABLE_SECURITY_LOGS=true
ENABLE_AUDIT_TRAIL=true

# CORS
CORS_ORIGIN=http://localhost:3000
